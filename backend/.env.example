# HumanProof Backend — Environment Variables
# Copy this file to .env and fill in values for your environment.
# .env is gitignored and should never be committed.

# ── App ────────────────────────────────────────────────────────────────────
HUMANPROOF_APP_NAME=HumanProof

# ── Database ───────────────────────────────────────────────────────────────
# Local development (SQLite — default, no extra setup needed)
HUMANPROOF_DATABASE_URL=sqlite+aiosqlite:///./humanproof.db

# Production (PostgreSQL — recommended for multi-user deployments)
# HUMANPROOF_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/humanproof

# ── CORS ───────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
HUMANPROOF_CORS_ORIGINS=["http://localhost:3000"]
# Production example:
# HUMANPROOF_CORS_ORIGINS=["https://humanproof.yourdomain.com"]

# ── Data Directory ─────────────────────────────────────────────────────────
# Path to the directory containing data files (e.g. genebass_pLoF_filtered.pkl)
# Defaults to <repo_root>/data if not set
# HUMANPROOF_DATA_DIR=/opt/humanproof/data

# ── Binding Predictor (Phase 3 — GPU) ─────────────────────────────────────
# Options: "mock" (default), "boltz2", "esm"
# BINDING_PREDICTOR=mock

# ── Logging ────────────────────────────────────────────────────────────────
# Set to "json" for structured logging in production
# LOG_FORMAT=json
